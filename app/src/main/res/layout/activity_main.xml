<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Title Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#3F51B5"
            android:padding="18dp"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Sensor App"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- ACCELEROMETER CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <!-- Orange top strip -->
            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:background="#FF5722"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCELEROMETER"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF5722"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <!-- X Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="30dp"
                    android:layout_height="wrap_content"
                    android:text="X"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="#FF5722"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/tvAccelX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0.0 m/s²"
                    android:textSize="15sp"
                    android:textColor="#333333"
                    android:paddingStart="12dp"/>
            </LinearLayout>

            <!-- Y Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="30dp"
                    android:layout_height="wrap_content"
                    android:text="Y"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="#FF5722"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/tvAccelY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0.0 m/s²"
                    android:textSize="15sp"
                    android:textColor="#333333"
                    android:paddingStart="12dp"/>
            </LinearLayout>

            <!-- Z Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="30dp"
                    android:layout_height="wrap_content"
                    android:text="Z"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="#FF5722"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/tvAccelZ"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0.0 m/s²"
                    android:textSize="15sp"
                    android:textColor="#333333"
                    android:paddingStart="12dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- LIGHT SENSOR CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <!-- Yellow top strip -->
            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:background="#FFC107"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIGHT SENSOR"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFA000"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Brightness"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvLight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 lux"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFA000"/>
            </LinearLayout>

        </LinearLayout>

        <!-- PROXIMITY SENSOR CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <!-- Green top strip -->
            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:background="#4CAF50"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROXIMITY SENSOR"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#388E3C"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvProximity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 cm"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#388E3C"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>

